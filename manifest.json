{
  "manifest_version": 3,
  "name": "Pure Vector - Image to SVG Converter",
  "version": "1.1.0",
  "description": "Convert PNG/JPEG images into scalable SVG vectors locally and securely in a full-screen dashboard.",
  "permissions": [
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Pure Vector Dashboard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}